# API配置示例文件
# 复制此文件为 .env 并填入你的实际配置

# ============ OpenAI 官方配置 ============
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_URL=
# OPENAI_MODEL=gpt-3.5-turbo

# ============ 智谱AI (GLM-4) ============
# OPENAI_API_KEY=your-zhipu-api-key
# OPENAI_API_URL=https://open.bigmodel.cn/api/paas/v4/
# OPENAI_MODEL=glm-4

# ============ 阿里云通义千问 ============
# OPENAI_API_KEY=your-dashscope-api-key
# OPENAI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-turbo

# ============ 百度文心一言 ============
# OPENAI_API_KEY=your-ernie-api-key
# OPENAI_API_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat
# OPENAI_MODEL=ERNIE-Bot-4

# ============ 月之暗面 Kimi ============
# OPENAI_API_KEY=your-moonshot-api-key
# OPENAI_API_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# ============ Groq ============
# OPENAI_API_KEY=your-groq-api-key
# OPENAI_API_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama3-8b-8192

# ============ Together AI ============
# OPENAI_API_KEY=your-together-api-key
# OPENAI_API_URL=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-3-8b-chat-hf

# ============ Azure OpenAI ============
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_API_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL=gpt-35-turbo

# ============ 通用配置 ============
# OPENAI_TEMPERATURE=0.7  # 温度参数：0-2，越高越随机
# OPENAI_MAX_TOKENS=2000  # 最大生成token数
